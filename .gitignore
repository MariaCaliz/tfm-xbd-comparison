data/raw/
data/processed/
data/splits/*.csv
!data/splits/.gitkeep
*.tar
*.tar.gz
*.zip

# ============================================================
# Resultados pesados
# ============================================================
results/checkpoints/*.pt
results/checkpoints/*.pth
results/checkpoints/*.ckpt
!results/checkpoints/.gitkeep
